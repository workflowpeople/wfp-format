  "app_workflows": [
    {
      "workflow_id": "wf-view-reports",
      "name": "View Financial Reports",
      "description": "## Purpose\nGenerates and displays the three core financial statements from your General Ledger data. No AI/LLM required.\n\n## When to use\n- Any time you want to see your current financial position\n- At month-end or quarter-end for a quick snapshot\n- To verify data after posting journal entries\n\n## Steps\n1. Generate Profit & Loss (Income Statement) for Q1 2025\n2. Generate Balance Sheet as of March 31, 2025\n3. Generate Cash Flow Statement for Q1 2025\n\n## Outputs\nAll three reports appear directly in the chat as formatted tables. No downloads needed — just scroll through the results.",
      "type": "automation",
      "nodes": "[{\"node_id\":\"node-start\",\"workflow_id\":\"wf-view-reports\",\"type\":\"tool\",\"label\":\"Start\",\"tool_id\":\"utils_workflow_start\",\"toolConfig\":{},\"toolParameters\":{},\"step_order\":1},{\"node_id\":\"node-pl\",\"workflow_id\":\"wf-view-reports\",\"type\":\"tool\",\"label\":\"Profit & Loss\",\"tool_id\":\"gl_report_pl\",\"toolParameters\":{\"from_date\":\"2025-01-01\",\"to_date\":\"2025-03-31\"},\"workflowMgmt\":{},\"step_order\":2},{\"node_id\":\"node-bs\",\"workflow_id\":\"wf-view-reports\",\"type\":\"tool\",\"label\":\"Balance Sheet\",\"tool_id\":\"gl_report_bs\",\"toolParameters\":{\"as_of_date\":\"2025-03-31\"},\"workflowMgmt\":{},\"step_order\":3},{\"node_id\":\"node-cf\",\"workflow_id\":\"wf-view-reports\",\"type\":\"tool\",\"label\":\"Cash Flow\",\"tool_id\":\"gl_report_cf\",\"toolParameters\":{\"from_date\":\"2025-01-01\",\"to_date\":\"2025-03-31\"},\"workflowMgmt\":{},\"step_order\":4},{\"node_id\":\"node-end\",\"workflow_id\":\"wf-view-reports\",\"type\":\"end\",\"label\":\"Done\",\"tool_id\":\"utils_workflow_end\",\"step_order\":5}]",
      "edges": "[{\"workflow_id\":\"wf-view-reports\",\"edge_id\":\"edge-01\",\"source_node_id\":\"node-start\",\"target_node_id\":\"node-pl\"},{\"workflow_id\":\"wf-view-reports\",\"edge_id\":\"edge-02\",\"source_node_id\":\"node-pl\",\"target_node_id\":\"node-bs\"},{\"workflow_id\":\"wf-view-reports\",\"edge_id\":\"edge-03\",\"source_node_id\":\"node-bs\",\"target_node_id\":\"node-cf\"},{\"workflow_id\":\"wf-view-reports\",\"edge_id\":\"edge-04\",\"source_node_id\":\"node-cf\",\"target_node_id\":\"node-end\"}]",
      "created_at": "2026-04-03T00:00:00.000Z",
      "updated_at": "2026-04-03T00:00:00.000Z",
      "version": 1,
      "snapshot_data": null,
      "builder_chat": null,
      "summary": "Generates P&L, Balance Sheet, and Cash Flow reports from pre-loaded GL data. No AI key required — run immediately to see your financials."
    },
    {
      "workflow_id": "wf-expense-report",
      "name": "Expense Categorization",
      "description": "## Purpose\nUses AI to categorize bank and credit card transactions against the chart of accounts and generates a spending summary by GL account.\n\n## When to use\n- After downloading new bank statements\n- To prepare data for month-end close\n- For ad-hoc spending analysis\n\n## Requirements\n- LLM API key configured\n- Bank transaction data loaded as `checking` and/or `credit_card`\n\n## Steps\n1. Load bank transaction data from workspace\n2. AI categorizes each transaction to a GL account\n3. Generate categorized expense report\n4. Download report as HTML\n\n## Outputs\n- Categorized transaction list with GL account assignments\n- Expense summary by account\n- Downloadable HTML report",
      "type": "automation",
      "nodes": "[{\"workflow_id\":\"wf-expense-report\",\"node_id\":\"node-start\",\"type\":\"tool\",\"label\":\"Start\",\"tool_id\":\"utils_workflow_start\",\"step_order\":1},{\"workflow_id\":\"wf-expense-report\",\"node_id\":\"node-categorize\",\"type\":\"tool\",\"label\":\"Categorize Transactions\",\"tool_id\":\"llm_step\",\"workflowMgmt\":{\"chatMsgBody\":\"Transactions categorized.\"},\"toolParameters\":{\"data\":\"{{[checking]}}\\n{{[credit_card]}}\",\"instructions\":\"Categorize each transaction to the appropriate GL expense account. Available accounts: Rent (5000), Utilities (5010), Office Supplies (5020), Software & Subscriptions (5030), Insurance (5040), Professional Services (5050), Marketing (5060), Travel (5070), Meals & Entertainment (5080), Payroll (5090), Miscellaneous (5900). For income: Service Revenue (4000), Product Revenue (4100). Output a JSON array: [ { \\\"date\\\": \\\"...\\\", \\\"description\\\": \\\"...\\\", \\\"amount\\\": number, \\\"account\\\": \\\"GL Account Name\\\", \\\"account_id\\\": \\\"5000\\\", \\\"confidence\\\": \\\"high|medium|low\\\" } ]. No explanation, just JSON.\",\"context\":\"Small service business. Amounts are negative for expenses, positive for income.\"},\"step_order\":2},{\"workflow_id\":\"wf-expense-report\",\"node_id\":\"node-report\",\"type\":\"tool\",\"label\":\"Generate Expense Report\",\"tool_id\":\"ctool-expense-html\",\"workflowMgmt\":{},\"toolParameters\":{\"categorized_json\":\"{{llm_result_data}}\"},\"step_order\":3},{\"workflow_id\":\"wf-expense-report\",\"node_id\":\"node-dl\",\"type\":\"tool\",\"label\":\"Download Report\",\"tool_id\":\"util_chat_download\",\"workflowMgmt\":{},\"toolParameters\":{\"data\":\"{{html_report}}\",\"filename\":\"expense_report.html\",\"label\":\"Download Expense Report\"},\"step_order\":4},{\"workflow_id\":\"wf-expense-report\",\"node_id\":\"node-end\",\"type\":\"end\",\"label\":\"End\",\"tool_id\":\"utils_workflow_end\",\"step_order\":5}]",
      "edges": "[{\"workflow_id\":\"wf-expense-report\",\"edge_id\":\"edge-01\",\"source_node_id\":\"node-start\",\"target_node_id\":\"node-categorize\"},{\"workflow_id\":\"wf-expense-report\",\"edge_id\":\"edge-02\",\"source_node_id\":\"node-categorize\",\"target_node_id\":\"node-report\"},{\"workflow_id\":\"wf-expense-report\",\"edge_id\":\"edge-03\",\"source_node_id\":\"node-report\",\"target_node_id\":\"node-dl\"},{\"workflow_id\":\"wf-expense-report\",\"edge_id\":\"edge-04\",\"source_node_id\":\"node-dl\",\"target_node_id\":\"node-end\"}]",
      "created_at": "2026-04-03T00:00:00.000Z",
      "updated_at": "2026-04-03T00:00:00.000Z",
      "version": 1,
      "snapshot_data": null,
      "builder_chat": null,
      "summary": "Uses AI to categorize bank and credit card transactions to GL accounts, then generates a downloadable expense summary report."
    },
    {
      "workflow_id": "wf-invoice-tracker",
      "name": "Invoice & AR Tracker",
      "description": "## Purpose\nTracks outstanding invoices, aging, and payment status. Generates an accounts receivable report and flags overdue invoices. No AI/LLM required.\n\n## When to use\n- Weekly to monitor outstanding invoices\n- When following up on late payments\n- At month-end for AR aging analysis\n\n## Requirements\n- Invoice data loaded as `invoices` (CSV: invoice_id, client, amount, issue_date, due_date, status)\n\n## Steps\n1. Load invoice data from workspace\n2. Calculate aging buckets (current, 30, 60, 90+ days)\n3. Generate styled AR aging report\n4. Download report as HTML\n\n## Outputs\n- AR aging summary with colored buckets\n- Overdue invoice list with priority flags\n- Downloadable HTML report",
      "type": "automation",
      "nodes": "[{\"node_id\":\"node-start\",\"workflow_id\":\"wf-invoice-tracker\",\"type\":\"tool\",\"label\":\"Start\",\"tool_id\":\"utils_workflow_start\",\"toolConfig\":{},\"toolParameters\":{},\"step_order\":1},{\"workflow_id\":\"wf-invoice-tracker\",\"node_id\":\"node-aging\",\"type\":\"tool\",\"label\":\"Calculate AR Aging\",\"tool_id\":\"ctool-ar-aging\",\"workflowMgmt\":{\"chatMsgBody\":\"AR aging calculated.\"},\"step_order\":2,\"toolParameters\":{\"invoices_data\":\"{{[invoices]}}\"}},{\"workflow_id\":\"wf-invoice-tracker\",\"node_id\":\"node-report\",\"type\":\"tool\",\"label\":\"Generate AR Report\",\"tool_id\":\"ctool-ar-html\",\"workflowMgmt\":{},\"step_order\":3,\"toolParameters\":{\"aging_data\":\"{{aging_data}}\"}},{\"workflow_id\":\"wf-invoice-tracker\",\"node_id\":\"node-dl\",\"type\":\"tool\",\"label\":\"Download Report\",\"tool_id\":\"util_chat_download\",\"workflowMgmt\":{},\"step_order\":4,\"toolParameters\":{\"data\":\"{{html_report}}\",\"filename\":\"ar_aging.html\",\"label\":\"Download AR Report\"}},{\"workflow_id\":\"wf-invoice-tracker\",\"node_id\":\"node-end\",\"type\":\"end\",\"label\":\"End\",\"tool_id\":\"utils_workflow_end\",\"step_order\":5}]",
      "edges": "[{\"workflow_id\":\"wf-invoice-tracker\",\"edge_id\":\"edge-01\",\"source_node_id\":\"node-start\",\"target_node_id\":\"node-aging\"},{\"workflow_id\":\"wf-invoice-tracker\",\"edge_id\":\"edge-02\",\"source_node_id\":\"node-aging\",\"target_node_id\":\"node-report\"},{\"workflow_id\":\"wf-invoice-tracker\",\"edge_id\":\"edge-03\",\"source_node_id\":\"node-report\",\"target_node_id\":\"node-dl\"},{\"workflow_id\":\"wf-invoice-tracker\",\"edge_id\":\"edge-04\",\"source_node_id\":\"node-dl\",\"target_node_id\":\"node-end\"}]",
      "created_at": "2026-04-03T00:00:00.000Z",
      "updated_at": "2026-04-03T00:00:00.000Z",
      "version": 1,
      "snapshot_data": null,
      "builder_chat": null,
      "summary": "Tracks outstanding invoices and calculates AR aging buckets. No AI key required — run weekly to monitor payments."
    }
